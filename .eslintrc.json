{
  "extends": "airbnb-base",
  "env": {
    "node": true,
    "jest": true
  },
  "rules": {
    "indent": ["error", 2],
    "quotes": ["error", "double"],
    "semi": ["error", "always"],
    "max-len": ["error", { "code": 100 }],
    "complexity": ["error", 10],
    "eqeqeq": ["error", "always"],
    "no-var": "error"
  }
}
